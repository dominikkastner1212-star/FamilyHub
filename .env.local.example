# Supabase – findest du im Supabase-Dashboard unter Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Standort für das Wetter (Kassel als Default)
NEXT_PUBLIC_WEATHER_LAT=51.3127
NEXT_PUBLIC_WEATHER_LON=9.4797
NEXT_PUBLIC_WEATHER_CITY=Kassel

# Anthropic API (für Foto-zu-Termin) – Key von console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-dein-key
